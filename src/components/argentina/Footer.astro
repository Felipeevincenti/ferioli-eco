---
import "../../styles/argentina/footer.css";
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__grid" data-stagger>
      <div class="footer__brand" data-reveal="fade-up">
        <div class="footer__logo">
          <img
            src="/images/argentina/logo.png"
            alt="FerioliEco"
            class="footer__logo-img"
          />
        </div>
        <p class="footer__desc">
          Somos Comercializadores validado por Ferioli S.A.
        </p>
      </div>

      <div class="footer__links">
        <div class="footer__col" data-reveal="fade-up">
          <h4 class="footer__heading">Equipo</h4>
          <a
            class="footer__link"
            href="https://www.feriolisa.com.ar"
            target="_blank"
            rel="noopener noreferrer">Ferioli S.A.</a
          >
          <a href="/" class="footer__link">Ferioli Eco</a>
          <a
            class="footer__link"
            href="https://ferioli-brasil.netlify.app"
            target="_blank"
            rel="noopener noreferrer">Ferioli Brasil</a
          >
        </div>

        <div class="footer__col" data-reveal="fade-up">
          <h4 class="footer__heading">Productos</h4>
          <p class="footer__link">Hidrogrúas</p>
          <p class="footer__link">Retro SWAT</p>
          <p class="footer__link">Equipos de elevación</p>
          <p class="footer__link">Equipos especiales</p>
        </div>

        <div class="footer__col" data-reveal="fade-up">
          <h4 class="footer__heading">Contacto</h4>
          <a
            class="footer__link"
            href="https://www.instagram.com/feriolieco/"
            target="_blank"
            rel="noopener noreferrer">@feriolieco</a
          >
          <a
            class="footer__link"
            href="https://wa.me/543416123456"
            target="_blank"
            rel="noopener noreferrer"
            data-reveal="fade-up">+54 341 6-123-456</a
          >
          <a
            class="footer__link"
            class="contact__btn"
            href="mailto:info@feriolieco.com"
            data-reveal="fade-up">info@feriolieco.com</a
          >
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <span>&copy; 2026 FERIOLI S.A. Todos los derechos reservados.</span>
    </div>
  </div>
</footer>

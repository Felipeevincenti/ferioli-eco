---
import "../../styles/argentina/official.css";
---

<section class="official">
  <div class="official__shape"></div>
  <div class="official__inner">
    <div class="official__body">
      <h2 class="official__title" data-reveal="slide-right">Centro Oficial FERIOLI</h2>
      <p class="official__text" data-reveal="slide-right">
        Somos una empresa oficial validada por <strong>FERIOLI S.A.</strong>,
        con acceso directo a la ingeniería del fabricante, repuestos originales
        y procedimientos técnicos certificados.
      </p>
      <p class="official__text" data-reveal="slide-right">
        Esto nos permite intervenir cada equipo con el mismo nivel de calidad
        con el que fue diseñado.
      </p>
    </div>

    <div class="official__items" data-stagger>
      <span class="official__item" data-reveal="slide-left">Validación oficial FERIOLI S.A.</span>
      <span class="official__item" data-reveal="slide-left">Técnicos especializados.</span>
      <span class="official__item" data-reveal="slide-left">Repuestos originales.</span>
      <span class="official__item" data-reveal="slide-left">Ingeniería aplicada.</span>
      <span class="official__item" data-reveal="slide-left">Servicio certificado.</span>
    </div>
  </div>
</section>


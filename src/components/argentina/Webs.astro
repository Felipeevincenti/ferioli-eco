---
import "../../styles/argentina/webs.css";
---

<section class="webs">
    <div class="webs__inner">
        <div class="webs__feriolisa" data-reveal="slide-right">
            <div class="feriolisa__info">
                <h2 class="feriolisa__title">
                    FERIOLI <span class="feriolisa__title-span">S.A.</span>
                </h2>
                <h4 class="feriolisa__subtitle">
                    Más de 75 años fabricando las hidrogrúas <br /> que impulsan la
                    industria latinoamericana.
                </h4>
                <p class="feriolisa__text">
                    FERIOLI S.A. es la única empresa argentina fabricante de
                    hidrogrúas de gran porte.
                </p>
                <p class="feriolisa__text">
                    Su ingeniería propia, fabricación integral y presencia
                    regional la convierten en un referente para la industria, la
                    energía, la minería y la infraestructura.
                </p>
            </div>
            <a
                class="feriolisa__button"
                href="https://www.feriolisa.com.ar"
                target="_blank"
                rel="noopener noreferrer">Conocer FERIOLI S.A. →</a
            >
        </div>
        <div class="webs__feriolibr" data-reveal="slide-left">
            <div class="feriolibr__info">
                <h2 class="feriolibr__title">
                    FERIOLI <span class="feriolibr__title-span">BRASIL</span>
                </h2>
                <h4 class="feriolibr__subtitle">
                    Ingeniería argentina con <br /> presencia regional.
                </h4>
                <p class="feriolibr__text">
                    FERIOLI continúa su expansión en Latinoamérica incorporando
                    operaciones en Brasil para ofrecer soluciones de elevación
                    con el mismo estándar de calidad, ingeniería y servicio.
                </p>
                <p class="feriolibr__text">
                    La presencia regional fortalece el soporte técnico, la
                    disponibilidad comercial y el crecimiento de la marca en
                    toda América Latina.
                </p>
            </div>
            <a
                class="feriolibr__button"
                href="https://ferioli-brasil.netlify.app"
                target="_blank"
                rel="noopener noreferrer"
            >
                Conocer FERIOLI Brasil →
            </a>
        </div>
    </div>
</section>

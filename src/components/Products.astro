---
import "../styles/products.css";
---

<section class="products" id="productos">
    <div class="products__inner">
        <h2 class="products__title" data-reveal="fade-up">Productos</h2><div class="products__grid" data-stagger>
            <article class="products__card" data-reveal="fade-up">
                <div class="products__card-image">
                    <img
                        src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=640&q=80&auto=format&fit=crop"
                        alt="Hidrogrúas"
                        loading="lazy"
                        width="640"
                        height="480"
                    />
                </div><div class="products__card-body">
                    <h3 class="products__card-title">Hidrogrúas</h3>
                </div>
            </article>
            <article class="products__card" data-reveal="fade-up">
                <div class="products__card-image">
                    <img
                        src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=640&q=80&auto=format&fit=crop"
                        alt="Retro SWAT"
                        loading="lazy"
                        width="640"
                        height="480"
                    />
                </div><div class="products__card-body">
                    <h3 class="products__card-title">Retro SWAT</h3>
                </div>
            </article>
            <article class="products__card" data-reveal="fade-up">
                <div class="products__card-image">
                    <img
                        src="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=640&q=80&auto=format&fit=crop"
                        alt="Equipos de elevación"
                        loading="lazy"
                        width="640"
                        height="480"
                    />
                </div><div class="products__card-body">
                    <h3 class="products__card-title">Equipos de elevación</h3>
                </div>
            </article>
            <article class="products__card" data-reveal="fade-up">
                <div class="products__card-image">
                    <img
                        src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=640&q=80&auto=format&fit=crop"
                        alt="Equipos especiales"
                        loading="lazy"
                        width="640"
                        height="480"
                    />
                </div><div class="products__card-body">
                    <h3 class="products__card-title">Equipos especiales</h3>
                </div>
            </article>
        </div>
    </div>
</section>

---
import "../styles/presence.css";
---

<section class="presence">
    <div class="presence__bg"></div>

    <div class="presence__inner">
        <div class="presence__layout">
            <div class="presence__content" data-reveal="slide-right">
                <h2 class="presence__title">Presencia</h2>
                <div class="presence__country">
                    <span class="presence__country-label"> Argentina </span>
                    <div class="presence__items">
                        <button
                            class="presence__btn is-active"
                            data-city="rosario"
                        >
                            <span class="presence__btn-dot"></span>
                            <div class="presence__btn-info">
                                <span class="presence__btn-title">
                                    Rosario
                                </span>
                            </div>
                            <span class="presence__btn-line"></span>
                        </button>

                        <button class="presence__btn" data-city="salta">
                            <span class="presence__btn-dot"></span>
                            <div class="presence__btn-info">
                                <span class="presence__btn-title"> Salta </span>
                            </div>
                            <span class="presence__btn-line"></span>
                        </button>
                    </div>
                </div>

                <div class="presence__country">
                    <span class="presence__country-label"> Brasil </span>

                    <div class="presence__items">
                        <button class="presence__btn" data-city="farroupilha">
                            <span class="presence__btn-dot"></span>
                            <div class="presence__btn-info">
                                <span class="presence__btn-title">
                                    Farroupilha
                                </span>
                            </div>
                            <span class="presence__btn-line"></span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="presence__map" data-reveal="scale-in">
                <img
                    id="presence-image"
                    class="presence__image"
                    src="/images/rosario.png"
                    alt="Rosario"
                />
            </div>
        </div>
    </div>
</section>

<script>
    const buttons = document.querySelectorAll(".presence__btn");
    const image = document.getElementById("presence-image");
    const map = document.querySelector(".presence__map");
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let rafId = null;
    let targetRotateX = 0;
    let targetRotateY = 0;
    let currentRotateX = 0;
    let currentRotateY = 0;

    buttons.forEach((button) => {
        button.addEventListener("click", () => {
            if (button.classList.contains("is-active")) return;

            buttons.forEach((btn) => btn.classList.remove("is-active"));

            button.classList.add("is-active");

            const city = button.dataset.city;

            image.style.opacity = "0";
            image.style.transform = "scale(.95)";

            setTimeout(() => {
                image.src = `/images/${city}.png`;

                image.alt = city;

                image.onload = () => {
                    image.style.opacity = "1";
                    image.style.transform = "scale(1)";
                };
            }, 180);
        });
    });

    if (!prefersReduced) {
        map.addEventListener("mousemove", (e) => {
            if (image.style.opacity === "0") return;

            const rect = map.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            const maxAngle = 12;
            targetRotateY = ((x - centerX) / centerX) * maxAngle;
            targetRotateX = -((y - centerY) / centerY) * maxAngle;

            if (!rafId) {
                const step = () => {
                    currentRotateX += (targetRotateX - currentRotateX) * 0.12;
                    currentRotateY += (targetRotateY - currentRotateY) * 0.12;

                    image.style.transform =
                        `perspective(800px) scale(1) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg)`;

                    if (Math.abs(targetRotateX - currentRotateX) > 0.01 ||
                        Math.abs(targetRotateY - currentRotateY) > 0.01) {
                        rafId = requestAnimationFrame(step);
                    } else {
                        rafId = null;
                    }
                };
                rafId = requestAnimationFrame(step);
            }
        });

        map.addEventListener("mouseleave", () => {
            targetRotateX = 0;
            targetRotateY = 0;
        });
    }
</script>

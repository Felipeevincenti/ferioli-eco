---
import "../styles/contact.css";
---

<section class="contact" id="contacto">
    <div class="contact__inner">
        <div class="contact__content">
            <h2 class="contact__title" data-reveal="fade-up">
                <span id="typed"></span>
            </h2>
            <p class="contact__message" data-reveal="fade-up">
                Nuestro equipo está listo para ayudarte.
            </p>
            <a
                class="contact__btn"
                href="https://wa.me/543416123456"
                target="_blank"
                rel="noopener noreferrer"
                data-reveal="fade-up"
            >
                Whatsapp
            </a>
        </div>
        <form class="contact__form" action="" data-reveal="fade-up">
            <div class="contact__form-block">
                <input
                    class="contact__input"
                    type="text"
                    placeholder="Nombre y Apellido"
                />
                <input
                    class="contact__input"
                    type="text"
                    placeholder="Empresa"
                />
            </div>
            <div class="contact__form-block">
                <input
                    class="contact__input"
                    type="tel"
                    placeholder="Teléfono"
                />
                <input
                    class="contact__input"
                    type="email"
                    placeholder="Email"
                />
            </div>
            <textarea class="contact__input" placeholder="Mensaje"></textarea>
            <input
                class="contact__submit"
                type="submit"
                value="Enviar mensaje →"
            />
        </form>
    </div>
</section>

<script type="module">
    import Typed from "typed.js";

    new Typed("#typed", {
        strings: ["¿Necesitás una hidrogrúa?", "¿Buscás servicio técnico?"],
        typeSpeed: 30,
        backSpeed: 30,
        backDelay: 3000,
        loop: true,
        showCursor: false,
    });
</script>

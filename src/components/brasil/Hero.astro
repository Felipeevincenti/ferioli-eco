---
import "../../styles/brasil/hero.css";
---

<section class="br-hero" id="hero">
  <div class="br-hero__bg">
    <img
      class="br-hero__image"
      src="/images/brasil/hero.jpg"
      alt="Grua FERIOLI em operação"
      loading="eager"
    />
  </div>
  <div class="br-hero__overlay"></div>
  <div class="br-hero__inner">
    <div class="br-hero__content">
      <h1 class="br-hero__title" data-reveal="fade-up">
        Há mais de 75 anos<br />
        <span class="br-hero__highlight">elevando a indústria</span><br />
        latino-americana.
      </h1>
      <p class="br-hero__subtitle" data-reveal="fade-up">
        A FERIOLI é a única fabricante argentina de guindastes de grande porte. Agora, nossa engenharia e tecnologia chegam ao Brasil para oferecer soluções robustas, seguras e desenvolvidas para a realidade da América Latina.
      </p>
      <div class="br-hero__actions" data-reveal="fade-up">
        <a href="#cta" class="br-hero__btn br-hero__btn--primary">Solicite um orçamento</a>
        <a href="#equipamentos" class="br-hero__btn br-hero__btn--secondary">Conheça nossos equipamentos</a>
      </div>
    </div>
  </div>
</section>

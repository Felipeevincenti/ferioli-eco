---
import "../../styles/brasil/applications.css";
---

<section class="br-apps" id="aplicacoes">
  <div class="br-apps__inner">
    <div class="br-apps__header" data-reveal="fade-up">
      <h2 class="br-apps__title">
        Desenvolvidos para os setores mais exigentes.
      </h2>
    </div>
  </div>
  <div class="br-apps__grid" data-stagger>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="../../../public/images/argentina/productos/hidrogrua.jpg"
        alt="Construção Civil"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Construção Civil</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="../../../public/images/argentina/productos/swat.jpg"
        alt="Energia"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Energia</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="../../../public/images/argentina/productos/elevacion.jpg"
        alt="Petróleo e Gás"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Petróleo e Gás</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="../../../public/images/argentina/productos/especiales.jpg"
        alt="Mineração"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Mineração</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="../../../public/images/argentina/repair.jpg"
        alt="Infraestrutura"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Infraestrutura</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="../../../public/images/argentina/official.jpg"
        alt="Indústria"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Indústria</span>
      </div>
    </figure>
  </div>
</section>

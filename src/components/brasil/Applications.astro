---
import "../../styles/brasil/applications.css";
---

<section class="br-apps" id="aplicacoes">
  <div class="br-apps__inner">
    <div class="br-apps__header" data-reveal="fade-up">
      <h2 class="br-apps__title">
        Desenvolvidos para os setores<br />mais exigentes.
      </h2>
    </div>
  </div>
  <div class="br-apps__grid" data-stagger>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img src="/images/productos-especiales.jpg" alt="Construção Civil" loading="lazy" />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Construção Civil</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=500&q=80&auto=format&fit=crop"
        alt="Energia"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Energia</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img src="/images/equipo.jpg" alt="Petróleo e Gás" loading="lazy" />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Petróleo e Gás</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img src="/images/panoramica.png" alt="Mineração" loading="lazy" />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Mineração</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img src="/images/evolution.jpg" alt="Infraestrutura" loading="lazy" />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Infraestrutura</span>
      </div>
    </figure>
    <figure class="br-apps__card" data-reveal="scale-in">
      <img
        src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=500&q=80&auto=format&fit=crop"
        alt="Indústria"
        loading="lazy"
      />
      <div class="br-apps__card-overlay">
        <span class="br-apps__card-label">Indústria</span>
      </div>
    </figure>
  </div>
</section>

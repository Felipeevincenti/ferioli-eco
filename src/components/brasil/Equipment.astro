---
import "../../styles/brasil/equipment.css";
---

<section class="br-equipment" id="equipamentos">
  <div class="br-equipment__inner">
    <div class="br-equipment__header" data-reveal="fade-up">
      <h2 class="br-equipment__title">
        Soluções para cada necessidade<br />de movimentação de cargas.
      </h2>
    </div>
    <div class="br-equipment__grid" data-stagger>
      <article class="br-equipment__card" data-reveal="fade-up">
        <div class="br-equipment__card-image">
          <img
            src="/images/brasil/equipamiento/grua.jpg"
            alt="Guindastes FERIOLI"
            loading="lazy"
            width="640"
            height="400"
          />
        </div>
        <div class="br-equipment__card-body">
          <span class="br-equipment__card-category">Linha Industrial</span>
          <h3 class="br-equipment__card-title">Guindastes</h3>
          <p class="br-equipment__card-text">
            Equipamentos de 1,5 a 92 toneladas desenvolvidos para operações industriais, construção civil, energia, mineração e petróleo.
          </p>
          <a href="#cta" class="br-equipment__btn br-equipment__btn--outline">Conheça a linha</a>
        </div>
      </article>
      <article class="br-equipment__card" data-reveal="fade-up">
        <div class="br-equipment__card-image">
          <img
            src="/images/brasil/equipamiento/grua-electrica.jpg"
            alt="Eletroguindastes FERIOLI"
            loading="lazy"
            width="640"
            height="400"
          />
        </div>
        <div class="br-equipment__card-body">
          <span class="br-equipment__card-category">Linha Elétrica</span>
          <h3 class="br-equipment__card-title">Eletroguindastes</h3>
          <p class="br-equipment__card-text">
            Movimentação de cargas com eficiência, baixo custo operacional e zero emissões.
          </p>
          <a href="#cta" class="br-equipment__btn br-equipment__btn--outline">Conheça a linha</a>
        </div>
      </article>
    </div>
  </div>
</section>

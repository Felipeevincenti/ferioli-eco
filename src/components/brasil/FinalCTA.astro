---
import "../../styles/brasil/final-cta.css";
---

<section class="br-cta" id="cta">
  <div class="br-cta__bg">
    <img
      src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=1600&q=85&auto=format&fit=crop"
      alt="Grua FERIOLI em operação"
      loading="lazy"
    />
  </div>
  <div class="br-cta__overlay"></div>
  <div class="br-cta__inner" data-reveal="fade-up">
    <h2 class="br-cta__title">
      Tecnologia internacional.<br />
      Engenharia latino-americana.
    </h2>
    <p class="br-cta__subtitle">
      Há mais de 75 anos construindo confiança.
    </p>
    <a href="mailto:comercial@ferioli.com.br" class="br-cta__btn br-cta__btn--primary">Solicite um orçamento</a>
  </div>
</section>
